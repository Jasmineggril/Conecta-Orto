{
  "buildCommand": "NODE_ENV=production pnpm --filter @workspace/conecta-orto run build",
  "outputDirectory": "artifacts/conecta-orto/dist/public",
  "installCommand": "pnpm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/handler" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
