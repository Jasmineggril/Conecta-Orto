{
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "artifacts/conecta-orto/dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets|favicon|robots|videos|planta).*)", "destination": "/index.html" }
  ]
}
